<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.collabora_odoo</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Collabora Online" string="Collabora Online" name="collabora_odoo" groups="base.group_system">
                    <block title="Collabora Online Settings" name="cool_settings_container">
                        <setting id="collabora_odoo" string="Collabora Online Server URL">
                          <field name="cool_public_url" placeholder="https://collabora-online.example.com:9980/"/>
                        </setting>
                        <setting id="collabora_odoo" string="Disable certificate checks (for development only)">
                          <field name="cool_disable_cert_check"/>
                        </setting>
                        <setting id="collabora_odoo" string="Odoo URL">
                          <field name="cool_wopi_host_url" placeholder="https://odoo.example.com/"/>
                        </setting>
                        <setting id="collabora_odoo" string="JWT Secret">
                          <field name="cool_jwt_secret"/>
                        </setting>
                        <setting id="collabora_odoo" string="Token TTL">
                          <field name="cool_jwt_ttl"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="res_config_settings_menu_action" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_id" ref="res_config_settings_view_form" />
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'collabora_odoo'}</field>
    </record>
</odoo>
